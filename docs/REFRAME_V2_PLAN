## Ana Orkestratör — Yeni processor.py

```python
"""
Reframe pipeline orkestratörü.
Tüm adımları sırasıyla çağırır ve sonucu döndürür.
"""
import logging
from .analyzers.scene_analyzer import detect_scenes
from .analyzers.person_analyzer import PersonAnalyzer
from .analyzers.speaker_analyzer import (
    match_speakers_to_persons,
    build_speaker_timeline,
)
from .analyzers.content_classifier import classify_content
from .strategies.podcast import PodcastStrategy
from .strategies.single_speaker import SingleSpeakerStrategy
from .strategies.gaming import GamingStrategy
from .strategies.generic import GenericStrategy
from .composition.keyframe_generator import generate_keyframes
from .models.types import (
    ContentType, TrackingMode, SmoothingConfig, ReframeResult,
)

logger = logging.getLogger(__name__)


STRATEGY_MAP = {
    ContentType.PODCAST: PodcastStrategy,
    ContentType.SINGLE_SPEAKER: SingleSpeakerStrategy,
    ContentType.GAMING: GamingStrategy,
    ContentType.GENERIC: GenericStrategy,
}


async def process_reframe(
    video_path: str,
    src_w: int,
    src_h: int,
    fps: float,
    duration_s: float,
    diarization_segments: list[dict],
    aspect_ratio: tuple[int, int] = (9, 16),
    tracking_mode: str = "x_only",
    content_type_hint: str | None = None,
    progress_callback=None,
) -> ReframeResult:
    """
    Ana reframe pipeline'ı.

    Adımlar:
    1. Sahne tespiti
    2. Multi-frame kişi tespiti
    3. Konuşmacı-kişi eşleştirme
    4. İçerik türü sınıflandırma
    5. Strateji uygulama
    6. Keyframe üretimi
    """
    tracking = TrackingMode(tracking_mode)

    # ─── ADIM 1: Sahne tespiti ───
    if progress_callback:
        await progress_callback("scene_detection", 0.1)

    scenes = detect_scenes(
        video_path,
        content_hint=content_type_hint or "generic",
    )
    logger.info(f"Sahne tespiti: {len(scenes)} sahne bulundu")

    # ─── ADIM 2: Multi-frame kişi tespiti ───
    if progress_callback:
        await progress_callback("person_detection", 0.3)

    analyzer = PersonAnalyzer()
    scene_analyses = analyzer.analyze_scenes(
        video_path, scenes, fps, src_w, src_h,
    )
    logger.info(
        f"Kişi tespiti tamamlandı. "
        f"Toplam frame analizi: "
        f"{sum(len(sa.frame_analyses) for sa in scene_analyses)}"
    )

    # ─── ADIM 3: Konuşmacı-kişi eşleştirme ───
    if progress_callback:
        await progress_callback("speaker_matching", 0.5)

    speaker_person_map = match_speakers_to_persons(
        scene_analyses, diarization_segments, src_w,
    )
    logger.info(
        f"Konuşmacı eşleştirme: {len(speaker_person_map)} eşleşme"
    )

    # ─── ADIM 4: İçerik türü sınıflandırma ───
    content_type = classify_content(
        scene_analyses, diarization_segments, content_type_hint,
    )
    logger.info(f"İçerik türü: {content_type.value}")

    # ─── ADIM 5: Strateji uygulama ───
    if progress_callback:
        await progress_callback("strategy", 0.7)

    strategy_class = STRATEGY_MAP.get(content_type, GenericStrategy)
    strategy = strategy_class(tracking_mode=tracking)
    decisions = strategy.generate_decisions(
        scene_analyses=scene_analyses,
        speaker_person_map=speaker_person_map,
        speaker_timeline=build_speaker_timeline(
            diarization_segments, speaker_person_map,
            min_speech_duration_s=strategy.config.min_speech_duration_s,
        ),
        src_w=src_w,
        src_h=src_h,
        aspect_ratio=aspect_ratio,
    )
    logger.info(
        f"Strateji tamamlandı. "
        f"Toplam segment: {sum(len(d.segments) for d in decisions)}"
    )

    # ─── ADIM 6: Keyframe üretimi ───
    if progress_callback:
        await progress_callback("keyframe_generation", 0.9)

    result = generate_keyframes(
        decisions=decisions,
        src_w=src_w,
        src_h=src_h,
        fps=fps,
        duration_s=duration_s,
        content_type=content_type,
        tracking_mode=tracking,
        aspect_ratio=aspect_ratio,
        config=strategy.config,
    )

    if progress_callback:
        await progress_callback("complete", 1.0)

    logger.info(
        f"Reframe tamamlandı. "
        f"Keyframe sayısı: {len(result.keyframes)}, "
        f"Sahne kesimi: {len(result.scene_cuts)}"
    )

    return result
