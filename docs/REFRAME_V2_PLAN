## Analyzer Modülleri — Detaylı Tasarım

### scene_analyzer.py

```python
"""
Sahne tespiti — FFmpeg scene filter + SSIM doğrulama

Mevcut sistemden farklar:
- SSIM ile yanlış pozitif temizleme (el hareketi, ışık değişimi gibi)
- Minimum sahne süresi filtresi
- İçerik türüne göre ayarlanabilir threshold
"""
import subprocess
import re
import cv2
import numpy as np
from ..models.types import SceneInterval


# İçerik türüne göre varsayılan eşikler
DEFAULT_THRESHOLDS = {
    "podcast": 0.08,    # Stüdyo ortamı, düşük eşik = daha hassas
    "gaming": 0.25,     # Oyun ekranı sürekli değişir, yüksek eşik
    "single": 0.12,     # Tek kişi, orta eşik
    "generic": 0.10,    # Genel
}

MIN_SCENE_DURATION_S = 0.5     # 0.5 saniyeden kısa sahneleri birleştir
MIN_CUT_GAP_S = 0.5            # 0.5 saniyeden yakın kesimler = tek kesim
SSIM_HARD_CUT_THRESHOLD = 0.4  # SSIM bu değerin altında = kesin sahne geçişi
SSIM_SOFT_CUT_THRESHOLD = 0.7  # Bu aralıkta = muhtemel geçiş, doğrulama gerek


def detect_scenes(
    video_path: str,
    threshold: float | None = None,
    content_hint: str = "generic",
    fps: float = 30.0,
) -> list[SceneInterval]:
    """
    Sahne geçişlerini tespit et.

    1. FFmpeg scene filter ile aday noktaları bul
    2. SSIM ile doğrula (yanlış pozitif temizle)
    3. Çok yakın/kısa sahneleri birleştir
    """
    if threshold is None:
        threshold = DEFAULT_THRESHOLDS.get(content_hint, 0.10)

    # Adım 1: FFmpeg scene filter
    cut_times = _ffmpeg_scene_detect(video_path, threshold)

    # Adım 2: SSIM doğrulama
    if len(cut_times) > 0:
        cut_times = _validate_with_ssim(video_path, cut_times, fps)

    # Adım 3: Yakın kesimleri birleştir
    cut_times = _merge_nearby_cuts(cut_times, MIN_CUT_GAP_S)

    # Adım 4: Sahne aralıklarını oluştur
    duration = _get_duration(video_path)
    scenes = _cuts_to_intervals(cut_times, duration)

    # Adım 5: Çok kısa sahneleri birleştir
    scenes = _merge_short_scenes(scenes, MIN_SCENE_DURATION_S)

    return scenes


def _ffmpeg_scene_detect(video_path: str, threshold: float) -> list[float]:
    """FFmpeg scene filter ile sahne geçiş zamanlarını bul"""
    cmd = [
        "ffmpeg", "-i", video_path,
        "-vf", f"select='gt(scene,{threshold})',showinfo",
        "-vsync", "0",
        "-f", "null", "-",
    ]
    result = subprocess.run(cmd, capture_output=True, text=True, timeout=120)
    times = []
    for match in re.finditer(r"pts_time:(\d+\.?\d*)", result.stderr):
        times.append(float(match.group(1)))
    return sorted(set(times))


def _validate_with_ssim(
    video_path: str, cut_times: list[float], fps: float
) -> list[float]:
    """
    SSIM ile sahne geçişlerini doğrula.
    Her geçiş noktasının önceki ve sonraki frame'ini karşılaştır.
    Düşük SSIM = gerçek sahne geçişi, yüksek SSIM = yanlış alarm.
    """
    validated = []
    cap = cv2.VideoCapture(video_path)

    for cut_time in cut_times:
        # Geçişin 1 frame öncesi ve sonrasını al
        before_time = max(0, cut_time - 1.0 / fps)
        after_time = cut_time + 1.0 / fps

        frame_before = _extract_frame(cap, before_time)
        frame_after = _extract_frame(cap, after_time)

        if frame_before is None or frame_after is None:
            validated.append(cut_time)  # Frame alınamadıysa güvenli tarafta kal
            continue

        # Karşılaştırma için küçült (hız için)
        h, w = 120, 160
        before_small = cv2.resize(frame_before, (w, h))
        after_small = cv2.resize(frame_after, (w, h))

        # Gri tonlamaya çevir
        before_gray = cv2.cvtColor(before_small, cv2.COLOR_BGR2GRAY)
        after_gray = cv2.cvtColor(after_small, cv2.COLOR_BGR2GRAY)

        # SSIM hesapla
        ssim = _compute_ssim(before_gray, after_gray)

        if ssim < SSIM_HARD_CUT_THRESHOLD:
            # Kesin sahne geçişi
            validated.append(cut_time)
        elif ssim < SSIM_SOFT_CUT_THRESHOLD:
            # Muhtemel geçiş — daha geniş bağlamla doğrula
            before_wide = _extract_frame(cap, max(0, cut_time - 0.5))
            after_wide = _extract_frame(cap, cut_time + 0.5)
            if before_wide is not None and after_wide is not None:
                bw_small = cv2.resize(
                    cv2.cvtColor(before_wide, cv2.COLOR_BGR2GRAY), (w, h)
                )
                aw_small = cv2.resize(
                    cv2.cvtColor(after_wide, cv2.COLOR_BGR2GRAY), (w, h)
                )
                wide_ssim = _compute_ssim(bw_small, aw_small)
                if wide_ssim < SSIM_SOFT_CUT_THRESHOLD:
                    validated.append(cut_time)
        # else: SSIM yüksek → yanlış alarm, es geç

    cap.release()
    return validated


def _compute_ssim(img1: np.ndarray, img2: np.ndarray) -> float:
    """Basit SSIM hesaplama (OpenCV dependency olmadan)"""
    C1 = (0.01 * 255) ** 2
    C2 = (0.03 * 255) ** 2

    img1 = img1.astype(np.float64)
    img2 = img2.astype(np.float64)

    mu1 = cv2.GaussianBlur(img1, (11, 11), 1.5)
    mu2 = cv2.GaussianBlur(img2, (11, 11), 1.5)

    mu1_sq = mu1 ** 2
    mu2_sq = mu2 ** 2
    mu1_mu2 = mu1 * mu2

    sigma1_sq = cv2.GaussianBlur(img1 ** 2, (11, 11), 1.5) - mu1_sq
    sigma2_sq = cv2.GaussianBlur(img2 ** 2, (11, 11), 1.5) - mu2_sq
    sigma12 = cv2.GaussianBlur(img1 * img2, (11, 11), 1.5) - mu1_mu2

    ssim_map = ((2 * mu1_mu2 + C1) * (2 * sigma12 + C2)) / (
        (mu1_sq + mu2_sq + C1) * (sigma1_sq + sigma2_sq + C2)
    )
    return float(ssim_map.mean())


def _extract_frame(cap: cv2.VideoCapture, time_s: float) -> np.ndarray | None:
    """VideoCapture'dan belirli zamandaki frame'i al"""
    cap.set(cv2.CAP_PROP_POS_MSEC, time_s * 1000)
    ret, frame = cap.read()
    return frame if ret else None


def _merge_nearby_cuts(cuts: list[float], min_gap: float) -> list[float]:
    """Çok yakın kesimleri birleştir"""
    if not cuts:
        return []
    merged = [cuts[0]]
    for cut in cuts[1:]:
        if cut - merged[-1] >= min_gap:
            merged.append(cut)
    return merged


def _cuts_to_intervals(cuts: list[float], duration: float) -> list[SceneInterval]:
    """Kesim noktalarını sahne aralıklarına çevir"""
    intervals = []
    boundaries = [0.0] + cuts + [duration]
    for i in range(len(boundaries) - 1):
        intervals.append(SceneInterval(
            start_s=boundaries[i],
            end_s=boundaries[i + 1],
        ))
    return intervals


def _merge_short_scenes(
    scenes: list[SceneInterval], min_duration: float
) -> list[SceneInterval]:
    """Çok kısa sahneleri önceki sahneyle birleştir"""
    if not scenes:
        return []
    merged = [scenes[0]]
    for scene in scenes[1:]:
        if scene.duration_s < min_duration:
            # Önceki sahneye ekle
            merged[-1] = SceneInterval(
                start_s=merged[-1].start_s,
                end_s=scene.end_s,
            )
        else:
            merged.append(scene)
    return merged


def _get_duration(video_path: str) -> float:
    """FFprobe ile video süresini al"""
    cmd = [
        "ffprobe", "-v", "quiet",
        "-show_entries", "format=duration",
        "-of", "csv=p=0",
        video_path,
    ]
    result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
    return float(result.stdout.strip())
