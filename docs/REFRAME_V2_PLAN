### base.py — BaseStrategy

```python
"""
Tüm stratejilerin temel sınıfı.
Ortak davranışları (smoothing, dead zone, minimum süre) burada tanımla.
Türe özgü davranışları alt sınıflar override eder.
"""
from abc import ABC, abstractmethod
from ..models.types import (
    SceneAnalysis, ReframeDecision, ReframeSegment,
    SpeakerPersonMapping, SmoothingConfig,
    TransitionType, TrackingMode,
)


class BaseStrategy(ABC):
    def __init__(
        self,
        tracking_mode: TrackingMode = TrackingMode.X_ONLY,
        smoothing_config: SmoothingConfig | None = None,
    ):
        self.tracking_mode = tracking_mode
        self.config = smoothing_config or self._default_config()

    @abstractmethod
    def _default_config(self) -> SmoothingConfig:
        """Türe özgü varsayılan smoothing ayarları"""
        ...

    @abstractmethod
    def generate_decisions(
        self,
        scene_analyses: list[SceneAnalysis],
        speaker_person_map: list[SpeakerPersonMapping],
        speaker_timeline: list[dict],
        src_w: int,
        src_h: int,
        aspect_ratio: tuple[int, int],
    ) -> list[ReframeDecision]:
        """Reframe kararlarını üret"""
        ...

    def _calculate_crop_center_x(
        self,
        target_x_normalized: float,
        src_w: int,
        aspect_ratio: tuple[int, int],
    ) -> float:
        """
        Hedef X pozisyonunu crop merkez X'ine çevir.
        Dead zone ve sınır kontrolü uygula.
        """
        # 9:16 için kaynak frame'den kesilecek genişlik
        out_w, out_h = aspect_ratio
        crop_w_ratio = (out_w / out_h) * (src_w / src_w)
        # Normalize: hedefin crop içinde kalmasını sağla
        half_crop = crop_w_ratio / 2 if crop_w_ratio < 1.0 else 0.5 / (out_h / out_w)

        # Sınır kontrolü: crop frame dışına taşmasın
        min_x = half_crop
        max_x = 1.0 - half_crop
        return max(min_x, min(max_x, target_x_normalized))

    def _apply_dead_zone(
        self,
        current_x: float,
        target_x: float,
        dead_zone: float,
    ) -> float:
        """
        Dead zone uygula: hedef mevcut pozisyondan
        dead_zone kadar uzakta değilse hareket etme.
        """
        delta = abs(target_x - current_x)
        if delta < dead_zone:
            return current_x  # Hareket etme
        return target_x

    def _apply_ema(
        self,
        current: float,
        previous: float,
        alpha: float,
    ) -> float:
        """Exponential Moving Average"""
        return alpha * current + (1.0 - alpha) * previous
```

### podcast.py — PodcastStrategy

```python
"""
Podcast/Interview stratejisi.

Özellikler:
- 2+ kişi genellikle sabit pozisyonlarda oturuyor
- Konuşmacı değişiminde SERT KESİM
- Konuşan kişiye odaklan
- Dead zone BÜYÜK (kişi hareket etmiyorsa crop da hareket etmemeli)
- Pre-roll: ses başlamadan 150ms önce kes
"""
from .base import BaseStrategy
from ..models.types import (
    SceneAnalysis, ReframeDecision, ReframeSegment,
    SpeakerPersonMapping, SmoothingConfig,
    TransitionType, TrackingMode, PersonTrajectory,
)


class PodcastStrategy(BaseStrategy):
    def _default_config(self) -> SmoothingConfig:
        return SmoothingConfig(
            ema_alpha=0.15,
            dead_zone_x=0.10,           # Geniş dead zone — sakin görüntü
            dead_zone_y=0.06,
            min_segment_duration_s=2.0,  # En az 2 saniye bir konuşmacıda kal
            min_speech_duration_s=1.5,   # 1.5 sn altı konuşma = geçiş yapma
            pre_roll_s=0.15,            # 150ms pre-roll
            max_pan_speed=0.2,
        )

    def generate_decisions(
        self,
        scene_analyses: list[SceneAnalysis],
        speaker_person_map: list[SpeakerPersonMapping],
        speaker_timeline: list[dict],
        src_w: int,
        src_h: int,
        aspect_ratio: tuple[int, int],
    ) -> list[ReframeDecision]:
        decisions = []
        sp_map = {m.speaker_id: m for m in speaker_person_map}

        for sa in scene_analyses:
            scene = sa.scene
            segments = []

            if sa.person_count == 0:
                # Kimse tespit edilemedi → merkez crop
                segments.append(ReframeSegment(
                    start_s=scene.start_s,
                    end_s=scene.end_s,
                    target_x=0.5,
                    target_y=0.5,
                    transition_in=TransitionType.NONE,
                    reason="no_person_detected",
                ))

            elif sa.person_count == 1:
                # Tek kişi → o kişiyi takip et
                traj = sa.trajectories[0]
                segments.extend(
                    self._single_person_segments(traj, scene, sa)
                )

            else:
                # 2+ kişi → konuşmacıya göre odaklan
                segments.extend(
                    self._multi_person_segments(
                        sa, speaker_timeline, sp_map, scene
                    )
                )

            # Minimum segment süresi filtresi
            segments = self._enforce_min_duration(segments)

            decisions.append(ReframeDecision(
                scene=scene,
                segments=segments,
            ))

        return decisions

    def _single_person_segments(
        self,
        trajectory: PersonTrajectory,
        scene,
        scene_analysis: SceneAnalysis,
    ) -> list[ReframeSegment]:
        """Tek kişili sahne — kişiyi takip et"""
        if trajectory.is_static:
            # Kişi yerinde duruyor → sabit crop
            return [ReframeSegment(
                start_s=scene.start_s,
                end_s=scene.end_s,
                target_x=trajectory.mean_x,
                target_y=trajectory.mean_y,
                transition_in=TransitionType.NONE,
                focused_person_id=trajectory.person_id,
                reason="static_single_person",
            )]

        # Kişi hareket ediyor → pozisyon keyframe'leri oluştur
        segments = []
        positions = trajectory.positions  # (time_s, x, y)

        prev_x = positions[0][1]
        segment_start = scene.start_s

        for i, (time_s, x, y) in enumerate(positions):
            # Dead zone kontrolü
            x = self._apply_dead_zone(x, prev_x, self.config.dead_zone_x)

            if i == len(positions) - 1 or abs(x - prev_x) > self.config.dead_zone_x:
                if i > 0:
                    segments.append(ReframeSegment(
                        start_s=segment_start,
                        end_s=time_s,
                        target_x=prev_x,
                        target_y=trajectory.mean_y,
                        transition_in=TransitionType.SMOOTH,
                        focused_person_id=trajectory.person_id,
                        reason="person_tracking",
                    ))
                    segment_start = time_s
                prev_x = x

        # Son segment
        if segment_start < scene.end_s:
            segments.append(ReframeSegment(
                start_s=segment_start,
                end_s=scene.end_s,
                target_x=prev_x,
                target_y=trajectory.mean_y,
                transition_in=TransitionType.SMOOTH,
                focused_person_id=trajectory.person_id,
                reason="person_tracking_final",
            ))

        return segments if segments else [ReframeSegment(
            start_s=scene.start_s,
            end_s=scene.end_s,
            target_x=trajectory.mean_x,
            target_y=trajectory.mean_y,
            transition_in=TransitionType.NONE,
            focused_person_id=trajectory.person_id,
            reason="single_person_fallback",
        )]

    def _multi_person_segments(
        self,
        scene_analysis: SceneAnalysis,
        speaker_timeline: list[dict],
        sp_map: dict,
        scene,
    ) -> list[ReframeSegment]:
        """
        Çok kişili sahne — konuşmacıya göre SERT KESİM ile odaklan.

        Algoritma:
        1. Bu sahne içindeki konuşmacı segmentlerini bul
        2. Her segment için konuşmacının kişisini bul (sp_map)
        3. O kişinin trajectory'sindeki pozisyonu al
        4. Segment başlangıcından pre_roll_s önce HARD CUT yap
        """
        segments = []

        # Bu sahne aralığındaki konuşmacı segmentlerini filtrele
        scene_speaker_segs = [
            s for s in speaker_timeline
            if s["end"] > scene.start_s and s["start"] < scene.end_s
        ]

        if not scene_speaker_segs:
            # Konuşmacı bilgisi yok → eğer kimse konuşmuyorsa ve konuşmacı değişmiyorsa en son ki kişide kal yeni konuşmacı gelene kadar
            

        # Her konuşmacı segmenti için crop pozisyonu belirle
        prev_end = scene.start_s
        for i, sp_seg in enumerate(scene_speaker_segs):
            person_id = sp_seg.get("person_id")
            speaker_id = sp_seg.get("speaker_id", 0)

            # Kişinin pozisyonunu bul
            target_x = 0.5  # Fallback
            for traj in scene_analysis.trajectories:
                if traj.person_id == person_id:
                    target_x = traj.mean_x
                    break

            # Pre-roll: ses başlamadan 150ms önce kes
            seg_start = max(
                prev_end,
                max(scene.start_s, sp_seg["start"] - self.config.pre_roll_s),
            )
            seg_end = min(scene.end_s, sp_seg["end"])

            # Boşluk varsa (konuşmacılar arası sessizlik) → önceki pozisyonda kal
            if seg_start > prev_end and segments:
                segments[-1] = ReframeSegment(
                    start_s=segments[-1].start_s,
                    end_s=seg_start,
                    target_x=segments[-1].target_x,
                    target_y=segments[-1].target_y,
                    transition_in=segments[-1].transition_in,
                    active_speaker_id=segments[-1].active_speaker_id,
                    focused_person_id=segments[-1].focused_person_id,
                    reason=segments[-1].reason,
                )

            transition = TransitionType.HARD_CUT if i > 0 else TransitionType.NONE
            segments.append(ReframeSegment(
                start_s=seg_start,
                end_s=seg_end,
                target_x=target_x,
                target_y=0.5,
                transition_in=transition,
                active_speaker_id=speaker_id,
                focused_person_id=person_id,
                reason="speaker_focus",
            ))
            prev_end = seg_end

        # Sahne sonuna kadar uzat
        if segments and segments[-1].end_s < scene.end_s:
            segments[-1] = ReframeSegment(
                start_s=segments[-1].start_s,
                end_s=scene.end_s,
                target_x=segments[-1].target_x,
                target_y=segments[-1].target_y,
                transition_in=segments[-1].transition_in,
                active_speaker_id=segments[-1].active_speaker_id,
                focused_person_id=segments[-1].focused_person_id,
                reason=segments[-1].reason + "_extended",
            )

        return segments

    def _enforce_min_duration(
        self, segments: list[ReframeSegment]
    ) -> list[ReframeSegment]:
        """
        Minimum segment süresi kuralını uygula.
        2 saniyeden kısa segmentleri öncekiyle birleştir.
        """
        if len(segments) <= 1:
            return segments

        merged = [segments[0]]
        for seg in segments[1:]:
            duration = seg.end_s - seg.start_s
            if duration < self.config.min_segment_duration_s:
                # Önceki segmente birleştir (önceki pozisyonda kal)
                merged[-1] = ReframeSegment(
                    start_s=merged[-1].start_s,
                    end_s=seg.end_s,
                    target_x=merged[-1].target_x,
                    target_y=merged[-1].target_y,
                    transition_in=merged[-1].transition_in,
                    active_speaker_id=merged[-1].active_speaker_id,
                    focused_person_id=merged[-1].focused_person_id,
                    reason=merged[-1].reason + "_merged",
                )
            else:
                merged.append(seg)

        return merged
