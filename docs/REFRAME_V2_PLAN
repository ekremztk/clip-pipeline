### keyframe_generator.py

```python
"""
ReframeDecision'ları nihai keyframe'lere dönüştürür.
Bu, frontend'e gönderilecek son çıktıdır.
"""
from ..models.types import (
    ReframeDecision, ReframeKeyframe, ReframeResult,
    TransitionType, SmoothingConfig, ContentType,
    TrackingMode,
)
from .smoothing import smooth_positions


def generate_keyframes(
    decisions: list[ReframeDecision],
    src_w: int,
    src_h: int,
    fps: float,
    duration_s: float,
    content_type: ContentType,
    tracking_mode: TrackingMode,
    aspect_ratio: tuple[int, int],
    config: SmoothingConfig,
) -> ReframeResult:
    """Tüm kararlardan keyframe listesi üret"""
    keyframes: list[ReframeKeyframe] = []
    scene_cuts: list[float] = []

    # Aspect ratio'ya göre crop genişliğini hesapla
    out_w, out_h = aspect_ratio
    crop_w = int(src_h * (out_w / out_h))  # 9:16 → crop_w = 1080 * 9/16 = 607
    crop_w = min(crop_w, src_w)

    for decision in decisions:
        scene = decision.scene
        scene_cuts.append(scene.start_s)

        for seg in decision.segments:
            # Normalize X → pixel offset
            offset_x = seg.target_x * src_w - crop_w / 2
            # Sınır kontrolü
            offset_x = max(0, min(src_w - crop_w, offset_x))

            offset_y = 0.0
            if tracking_mode == TrackingMode.DYNAMIC_XY:
                crop_h = src_h  # 9:16'da tüm yüksekliği kullanıyoruz
                offset_y = seg.target_y * src_h - crop_h / 2
                offset_y = max(0, min(src_h - crop_h, offset_y))

            if seg.transition_in == TransitionType.HARD_CUT:
                # Sert kesim: önceki pozisyonda hold, sonra anında değiş
                # Hold keyframe (önceki segment sonuna)
                if keyframes:
                    hold_time = max(
                        keyframes[-1].time_s + 0.001,
                        seg.start_s - 1.0 / fps,
                    )
                    keyframes.append(ReframeKeyframe(
                        time_s=hold_time,
                        offset_x=keyframes[-1].offset_x,
                        offset_y=keyframes[-1].offset_y,
                        interpolation="hold",
                    ))
                # Yeni pozisyon
                keyframes.append(ReframeKeyframe(
                    time_s=seg.start_s,
                    offset_x=offset_x,
                    offset_y=offset_y,
                    interpolation="linear",
                ))

            elif seg.transition_in == TransitionType.SMOOTH:
                # Yumuşak geçiş — linear interpolation
                keyframes.append(ReframeKeyframe(
                    time_s=seg.start_s,
                    offset_x=offset_x,
                    offset_y=offset_y,
                    interpolation="linear",
                ))

            else:  # TransitionType.NONE
                # İlk segment veya değişim yok
                keyframes.append(ReframeKeyframe(
                    time_s=seg.start_s,
                    offset_x=offset_x,
                    offset_y=offset_y,
                    interpolation="linear",
                ))

    # Duplicate keyframe'leri temizle
    keyframes = _deduplicate_keyframes(keyframes)

    return ReframeResult(
        keyframes=keyframes,
        scene_cuts=scene_cuts[1:],  # İlk sahne başlangıcı kesim değil
        src_w=src_w,
        src_h=src_h,
        fps=fps,
        duration_s=duration_s,
        content_type=content_type,
        tracking_mode=tracking_mode,
        metadata={
            "total_segments": sum(len(d.segments) for d in decisions),
            "total_scenes": len(decisions),
        },
    )


def _deduplicate_keyframes(
    keyframes: list[ReframeKeyframe],
) -> list[ReframeKeyframe]:
    """Aynı zamanda ve aynı pozisyonda olan keyframe'leri temizle"""
    if not keyframes:
        return []

    deduped = [keyframes[0]]
    for kf in keyframes[1:]:
        prev = deduped[-1]
        # Aynı zaman ve aynı pozisyon → atla
        if (abs(kf.time_s - prev.time_s) < 0.001 and
            abs(kf.offset_x - prev.offset_x) < 1.0):
            continue
        deduped.append(kf)

    return deduped
