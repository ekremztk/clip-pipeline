## Smoothing + Keyframe Üretimi

### smoothing.py

```python
"""
Temporal smoothing ve dead zone uygulaması.
ReframeDecision'ları alır, yumuşatılmış pozisyonlar üretir.
"""
from ..models.types import SmoothingConfig


def smooth_positions(
    positions: list[tuple[float, float]],  # (time_s, target_x)
    config: SmoothingConfig,
) -> list[tuple[float, float]]:
    """
    EMA smoothing uygula.
    Smooth geçişlerde kullanılır (kişi hareketi takibi).
    Hard cut'larda smoothing UYGULANMAZ.
    """
    if len(positions) <= 1:
        return positions

    smoothed = [positions[0]]
    for i in range(1, len(positions)):
        time_s, raw_x = positions[i]
        _, prev_x = smoothed[i - 1]

        # EMA
        smooth_x = config.ema_alpha * raw_x + (1 - config.ema_alpha) * prev_x

        # Max pan speed limiti
        dt = time_s - positions[i - 1][0]
        if dt > 0:
            max_delta = config.max_pan_speed * dt
            delta = smooth_x - prev_x
            if abs(delta) > max_delta:
                smooth_x = prev_x + max_delta * (1 if delta > 0 else -1)

        smoothed.append((time_s, smooth_x))

    return smoothed
