### content_classifier.py

```python
"""
İçerik türü otomatik sınıflandırma.

Analiz sonuçlarına bakarak videonun podcast, single_speaker,
gaming veya generic olduğunu tespit eder.
"""
from ..models.types import ContentType, SceneAnalysis


def classify_content(
    scene_analyses: list[SceneAnalysis],
    diarization_segments: list[dict],
    user_hint: str | None = None,
) -> ContentType:
    """
    İçerik türünü belirle.
    Kullanıcı hint verdiyse onu kullan, yoksa otomatik tespit et.
    """
    if user_hint:
        try:
            return ContentType(user_hint)
        except ValueError:
            pass  # Geçersiz hint, otomatik tespite devam

    if not scene_analyses:
        return ContentType.GENERIC

    # İstatistikleri hesapla
    total_persons = []
    total_movement = []
    scene_durations = []

    for sa in scene_analyses:
        total_persons.append(sa.person_count)
        scene_durations.append(sa.scene.duration_s)
        for traj in sa.trajectories:
            total_movement.append(traj.x_range)

    avg_persons = sum(total_persons) / len(total_persons) if total_persons else 0
    avg_movement = sum(total_movement) / len(total_movement) if total_movement else 0
    avg_scene_duration = (
        sum(scene_durations) / len(scene_durations) if scene_durations else 0
    )
    num_speakers = len(set(
        seg.get("speaker", 0) for seg in diarization_segments
    )) if diarization_segments else 0

    # Karar ağacı
    if avg_persons >= 1.5 and avg_movement < 0.10 and avg_scene_duration > 3.0:
        # Birden fazla kişi, az hareket, uzun sahneler → podcast
        return ContentType.PODCAST

    if avg_persons <= 1.2 and avg_movement < 0.15:
        # Tek kişi, az-orta hareket → single speaker
        return ContentType.SINGLE_SPEAKER

    if avg_persons <= 1.0 and avg_movement > 0.20:
        # Tek veya sıfır kişi (küçük webcam), çok hareket → gaming
        return ContentType.GAMING

    return ContentType.GENERIC
