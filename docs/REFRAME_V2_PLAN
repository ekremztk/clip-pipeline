### person_analyzer.py

```python
"""
Multi-frame kişi tespiti ve takibi.

Mevcut sistemden temel fark: Her sahne için BİRDEN FAZLA frame analiz edilir.
Frame'ler arası kişi eşleştirmesi IoU ile yapılır.
Sonuç olarak her kişi için bir "trajectory" (hareket yolu) üretilir.
"""
import subprocess
import tempfile
import os
import cv2
import numpy as np
from ultralytics import YOLO
from ..models.types import (
    BBox, PersonDetection, FrameAnalysis,
    PersonTrajectory, SceneInterval, SceneAnalysis,
)


CONFIDENCE_THRESHOLD = 0.50
IOU_MATCH_THRESHOLD = 0.30    # Kişi eşleştirme için minimum IoU
MAX_PERSONS = 4               # Sahne başına maximum kişi
ANALYSIS_RESOLUTION = (640, 360)  # Analiz için küçültme (hız için)


class PersonAnalyzer:
    def __init__(self, model_path: str = "yolov8n-pose.pt"):
        self.model = YOLO(model_path)

    def analyze_scenes(
        self,
        video_path: str,
        scenes: list[SceneInterval],
        fps: float,
        src_w: int,
        src_h: int,
    ) -> list[SceneAnalysis]:
        """Tüm sahneleri analiz et"""
        results = []
        cap = cv2.VideoCapture(video_path)

        for scene in scenes:
            analysis = self._analyze_scene(cap, scene, fps, src_w, src_h)
            results.append(analysis)

        cap.release()
        return results

    def _analyze_scene(
        self,
        cap: cv2.VideoCapture,
        scene: SceneInterval,
        fps: float,
        src_w: int,
        src_h: int,
    ) -> SceneAnalysis:
        """Tek bir sahneyi analiz et — multi-frame"""
        # Örnekleme zamanlarını belirle
        sample_times = self._get_sample_times(scene, fps)

        # Her frame'i analiz et
        frame_analyses = []
        for i, time_s in enumerate(sample_times):
            frame = self._extract_frame(cap, time_s)
            if frame is None:
                continue

            # YOLOv8 inference
            detections = self._detect_persons(frame, src_w, src_h)

            frame_analyses.append(FrameAnalysis(
                time_s=time_s,
                persons=detections,
                frame_index=i,
            ))

        # Frame'ler arası kişi eşleştirmesi
        self._assign_person_ids(frame_analyses)

        # Trajectory'leri oluştur
        trajectories = self._build_trajectories(frame_analyses)

        # Kişi sayısını belirle
        person_count = len(trajectories)

        return SceneAnalysis(
            scene=scene,
            frame_analyses=frame_analyses,
            trajectories=trajectories,
            person_count=person_count,
        )

    def _get_sample_times(
        self, scene: SceneInterval, fps: float
    ) -> list[float]:
        """
        Sahne uzunluğuna göre örnekleme zamanlarını belirle.
        Kısa sahneler: 3 frame (baş, orta, son)
        Orta sahneler: 1 fps
        Uzun sahneler: 0.5 fps
        """
        duration = scene.duration_s

        if duration < 1.0:
            # Çok kısa sahne — sadece ortasını al
            return [scene.start_s + duration / 2]

        if duration < 3.0:
            # Kısa sahne — baş, orta, son
            return [
                scene.start_s + 0.1,
                scene.start_s + duration / 2,
                scene.end_s - 0.1,
            ]

        if duration <= 10.0:
            # Orta sahne — 1 fps
            sample_fps = 1.0
        else:
            # Uzun sahne — 0.5 fps
            sample_fps = 0.5

        times = []
        t = scene.start_s + 0.1  # İlk frame'i biraz kaydır (geçiş artefaktı)
        while t < scene.end_s - 0.1:
            times.append(t)
            t += 1.0 / sample_fps

        # Son frame'i de ekle
        if times and (scene.end_s - 0.1 - times[-1]) > 0.3:
            times.append(scene.end_s - 0.1)

        return times

    def _extract_frame(
        self, cap: cv2.VideoCapture, time_s: float
    ) -> np.ndarray | None:
        """Frame extract et"""
        cap.set(cv2.CAP_PROP_POS_MSEC, time_s * 1000)
        ret, frame = cap.read()
        return frame if ret else None

    def _detect_persons(
        self, frame: np.ndarray, src_w: int, src_h: int
    ) -> list[PersonDetection]:
        """YOLOv8 ile kişi tespiti"""
        # Küçült (hız için)
        small = cv2.resize(frame, ANALYSIS_RESOLUTION)
        scale_x = src_w / ANALYSIS_RESOLUTION[0]
        scale_y = src_h / ANALYSIS_RESOLUTION[1]

        results = self.model(small, verbose=False, conf=CONFIDENCE_THRESHOLD)
        detections = []

        for result in results:
            if result.keypoints is None:
                continue

            boxes = result.boxes
            keypoints = result.keypoints

            for i in range(len(boxes)):
                if int(boxes.cls[i]) != 0:  # Sadece person (class 0)
                    continue

                # Bbox normalize et
                x1, y1, x2, y2 = boxes.xyxy[i].cpu().numpy()
                bbox = BBox(
                    x=float(x1 * scale_x / src_w),
                    y=float(y1 * scale_y / src_h),
                    w=float((x2 - x1) * scale_x / src_w),
                    h=float((y2 - y1) * scale_y / src_h),
                )

                # Pose keypoints normalize et
                kps = keypoints.data[i].cpu().numpy()
                pose_kps = []
                for kp in kps:
                    pose_kps.append((
                        float(kp[0] * scale_x / src_w),   # x normalize
                        float(kp[1] * scale_y / src_h),   # y normalize
                        float(kp[2]),                      # confidence
                    ))

                detections.append(PersonDetection(
                    bbox=bbox,
                    confidence=float(boxes.conf[i]),
                    pose_keypoints=pose_kps,
                ))

        # Confidence'a göre sırala, en fazla MAX_PERSONS tane
        detections.sort(key=lambda d: d.confidence, reverse=True)
        return detections[:MAX_PERSONS]

    def _assign_person_ids(self, frame_analyses: list[FrameAnalysis]) -> None:
        """
        Frame'ler arası kişi eşleştirmesi.
        İlk frame'deki kişilere ID ata, sonraki frame'lerde
        IoU ile en yakın eşleşmeyi bul.
        """
        if not frame_analyses:
            return

        # İlk frame'e ID ata
        for i, person in enumerate(frame_analyses[0].persons):
            person.person_id = i

        # Sonraki frame'leri eşleştir
        for f_idx in range(1, len(frame_analyses)):
            prev_persons = frame_analyses[f_idx - 1].persons
            curr_persons = frame_analyses[f_idx].persons

            # Her mevcut kişi için önceki frame'deki en yakın eşleşmeyi bul
            used_prev = set()
            for curr in curr_persons:
                best_iou = 0.0
                best_prev_id = None

                for prev in prev_persons:
                    if prev.person_id in used_prev:
                        continue
                    iou = curr.bbox.iou(prev.bbox)
                    if iou > best_iou and iou > IOU_MATCH_THRESHOLD:
                        best_iou = iou
                        best_prev_id = prev.person_id

                if best_prev_id is not None:
                    curr.person_id = best_prev_id
                    used_prev.add(best_prev_id)
                else:
                    # Yeni kişi — yeni ID ata
                    max_id = max(
                        (p.person_id for fa in frame_analyses for p in fa.persons
                         if p.person_id is not None),
                        default=-1,
                    )
                    curr.person_id = max_id + 1

    def _build_trajectories(
        self, frame_analyses: list[FrameAnalysis]
    ) -> list[PersonTrajectory]:
        """Frame analizlerinden kişi trajectory'lerini oluştur"""
        person_positions: dict[int, list[tuple[float, float, float]]] = {}

        for fa in frame_analyses:
            for person in fa.persons:
                if person.person_id is None:
                    continue
                if person.person_id not in person_positions:
                    person_positions[person.person_id] = []
                person_positions[person.person_id].append((
                    fa.time_s,
                    person.head_center_x,
                    person.head_center_y,
                ))

        trajectories = []
        for pid, positions in person_positions.items():
            # En az 2 frame'de görünen kişileri dahil et
            if len(positions) >= 2 or len(frame_analyses) <= 2:
                trajectories.append(PersonTrajectory(
                    person_id=pid,
                    positions=positions,
                ))

        # X pozisyonuna göre sırala (soldan sağa)
        trajectories.sort(key=lambda t: t.mean_x)
        return trajectories
