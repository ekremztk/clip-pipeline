### speaker_analyzer.py

```python
"""
Konuşmacı-kişi eşleştirme.

Deepgram diarization verisindeki konuşmacıları (speaker 0, 1, ...)
YOLOv8'in tespit ettiği kişilerle eşleştirir.

Strateji: Pozisyon bazlı eşleştirme.
Podcast düzeninde genellikle soldaki kişi = host, sağdaki = guest.
Deepgram'da speaker 0 genellikle ilk konuşan kişi.
"""
from ..models.types import (
    SceneAnalysis, PersonTrajectory,
    SpeakerPersonMapping, SceneInterval,
)


def match_speakers_to_persons(
    scene_analyses: list[SceneAnalysis],
    diarization_segments: list[dict],
    src_w: int,
) -> list[SpeakerPersonMapping]:
    """
    Konuşmacıları tespit edilen kişilerle eşleştir.

    Algoritma:
    1. Diarization segmentlerinden unique konuşmacıları bul
    2. Tüm sahnelerdeki kişi trajectory'lerinden ortalama pozisyonları hesapla
    3. Konuşmacıları pozisyon sırasına göre kişilerle eşleştir
       (soldaki kişi = ilk konuşmacı — podcast konvansiyonu)
    4. Eşleştirme güvenilirliğini hesapla
    """
    if not diarization_segments or not scene_analyses:
        return []

    # Unique konuşmacıları bul
    unique_speakers = sorted(set(
        seg.get("speaker", 0) for seg in diarization_segments
    ))

    # Tüm sahnelerdeki kişilerin global ortalama pozisyonlarını hesapla
    global_person_positions: dict[int, list[float]] = {}
    for sa in scene_analyses:
        for traj in sa.trajectories:
            if traj.person_id not in global_person_positions:
                global_person_positions[traj.person_id] = []
            global_person_positions[traj.person_id].append(traj.mean_x)

    if not global_person_positions:
        return []

    # Her kişinin global ortalama X pozisyonu
    person_avg_x = {
        pid: sum(xs) / len(xs)
        for pid, xs in global_person_positions.items()
    }

    # Kişileri soldan sağa sırala
    sorted_persons = sorted(person_avg_x.items(), key=lambda x: x[1])

    # Eşleştirme: soldan sağa kişiler ↔ sırayla konuşmacılar
    mappings = []
    for i, speaker_id in enumerate(unique_speakers):
        if i < len(sorted_persons):
            person_id, avg_x = sorted_persons[i]
            # Güvenilirlik: kişi sayısı ve konuşmacı sayısı eşleşiyorsa yüksek
            confidence = 0.9 if len(unique_speakers) == len(sorted_persons) else 0.6
            mappings.append(SpeakerPersonMapping(
                speaker_id=speaker_id,
                person_id=person_id,
                confidence=confidence,
                avg_position_x=avg_x,
            ))

    return mappings


def get_active_speaker_at(
    time_s: float,
    diarization_segments: list[dict],
    min_speech_duration_s: float = 1.5,
) -> int | None:
    """
    Belirli bir zamanda aktif konuşmacıyı bul.
    Minimum konuşma süresi kuralını uygula.
    """
    # O andaki tüm aktif segmentleri bul
    active_segments = [
        seg for seg in diarization_segments
        if seg.get("start", 0) <= time_s <= seg.get("end", 0)
    ]

    if not active_segments:
        return None

    # En uzun segmentteki konuşmacıyı döndür
    longest = max(
        active_segments,
        key=lambda s: s.get("end", 0) - s.get("start", 0),
    )

    duration = longest.get("end", 0) - longest.get("start", 0)
    if duration < min_speech_duration_s:
        return None  # Çok kısa — geçiş yapma

    return longest.get("speaker", 0)


def build_speaker_timeline(
    diarization_segments: list[dict],
    speaker_person_map: list[SpeakerPersonMapping],
    min_speech_duration_s: float = 1.5,
    min_segment_gap_s: float = 0.3,
) -> list[dict]:
    """
    Diarization segmentlerinden temizlenmiş konuşmacı timeline'ı oluştur.

    Kurallar:
    - min_speech_duration_s'den kısa konuşmaları filtrele
    - Çok yakın segmentleri birleştir
    - Speaker ID → Person ID eşleştirmesini uygula
    """
    if not diarization_segments:
        return []

    # Speaker → Person mapping dict
    sp_map = {m.speaker_id: m.person_id for m in speaker_person_map}

    # Filtrele: çok kısa segmentleri çıkar
    filtered = []
    for seg in diarization_segments:
        duration = seg.get("end", 0) - seg.get("start", 0)
        if duration >= min_speech_duration_s:
            filtered.append({
                "start": seg["start"],
                "end": seg["end"],
                "speaker_id": seg.get("speaker", 0),
                "person_id": sp_map.get(seg.get("speaker", 0)),
            })

    # Aynı konuşmacının ardışık segmentlerini birleştir
    merged = []
    for seg in filtered:
        if (merged and
            merged[-1]["speaker_id"] == seg["speaker_id"] and
            seg["start"] - merged[-1]["end"] < min_segment_gap_s):
            merged[-1]["end"] = seg["end"]
        else:
            merged.append(dict(seg))

    return merged
