# --- Vertex AI ---
GCP_PROJECT=
GCP_LOCATION=us-central1
GCP_CREDENTIALS_JSON=

# --- Transcription ---
DEEPGRAM_API_KEY=

# --- Database ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=
DATABASE_URL=postgresql://...@xxx.supabase.co:6543/postgres
# Port MUST be 6543 (Connection Pooler)

# --- Frontend ---
FRONTEND_URL=https://xxx.vercel.app

# --- Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=prognot-clips
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# --- Cloudflare WARP proxy (YouTube download bypass) ---
# Generate once: docker run --rm virbr/wgcf register --accept-tos && wgcf generate
# Then copy PrivateKey and Address from wgcf-profile.conf
WARP_PRIVATE_KEY=
WARP_ADDRESS=172.16.0.2/32